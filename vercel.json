{
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "site/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/now-playing",
      "dest": "/api/now-playing.js"
    },
    {
      "src": "/api/lanyard",
      "dest": "/api/lanyard.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/site/$1"
    }
  ]
}
